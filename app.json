{
  "expo": {
    "name": "Beepr",
    "slug": "beepr-native",
    "scheme": "beepr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#130008"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.beepr.app.new",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification",
          "location",
          "fetch",
          "remote-notification"
        ],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Beepr needs your location to find cannabis dispensaries near you and send proximity alerts.",
        "NSLocationAlwaysUsageDescription": "Beepr uses your location in the background to detect when you're near a dispensary.",
        "NSLocationWhenInUseUsageDescription": "Beepr needs your location to find dispensaries near you.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.beepr.app.new",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#130008"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "router": {
      "origin": "https://beepr.com.br"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Beepr needs your location to find dispensaries near you and send proximity alerts.",
          "locationAlwaysPermission": "Beepr uses your location in the background to detect when you're near a dispensary.",
          "locationWhenInUsePermission": "Beepr needs your location to find dispensaries near you.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#c4185c",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "335de62d-fea8-4ad9-bae1-605f6ec60dca"
      }
    }
  }
}
